{
  "name": "@repo/shared-types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas.js",
      "types": "./dist/schemas.d.ts"
    },
    "./api": {
      "types": "./dist/api.d.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../../openapi.yaml -o ./src/api-schema.d.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "openapi-typescript": "^7.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.7.3"
  }
}