{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@/*": ["./src/*"],
      "@repo/shared-config/*": ["../shared-config/*"]
    }
  },
  "references": [
    { "path": "../shared-config" }
  ],
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}