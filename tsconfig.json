{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@repo/shared-utils": ["packages/shared-utils/src"],
      "@repo/shared-config": ["packages/shared-config"],
      "@repo/shared-types": ["packages/shared-types"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist"
  },
  "include": [],
  "exclude": ["node_modules", "dist", "build"],
  "references": [
    {"path": "./packages/shared-utils"},
    {"path": "./packages/shared-config"},
    {"path": "./packages/shared-types"},
  ]
}