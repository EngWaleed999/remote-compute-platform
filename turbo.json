{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"], 
  "tasks": {
      "codegen": {
      "cache": false
    },
    "build": {
      "dependsOn": ["codegen","^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": { 
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    
    "lint": {}
  }
}